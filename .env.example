# ---- MongoDB Atlas ----
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/gallery?retryWrites=true&w=majority

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Auth (single admin) ----
# Username the admin logs in with
ADMIN_USER=admin
# bcrypt hash of the admin password. Generate with: npm run hash -- "yourStrongPassword"
ADMIN_PASSWORD_HASH=$2a$12$replace_this_with_a_real_bcrypt_hash
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ---- Server ----
PORT=5000
# Origin of the client app (used for CORS + secure cookie). Comma-separated for multiple.
CLIENT_ORIGIN=http://localhost:5173
# Set to "production" in deployment so cookies are marked Secure
NODE_ENV=development
